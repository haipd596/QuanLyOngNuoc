# docker build -t cmcportal.fe .
#Stage 1
FROM node:20-alpine AS build-stage
WORKDIR /app
ARG VITE_API_URL
ARG VITE_DES_ENCRYPT_KEY
ARG VITE_ARTICLE_API_URL
ARG VITE_TINYMCE_LICENSE_KEY
ARG VITE_RESOURCE_URL
ARG VITE_RESOURCE_PROJECT_URL
ARG VITE_API_DVC_URL
ARG VITE_APP_VERSION

ENV VITE_API_URL=$VITE_API_URL
ENV VITE_DES_ENCRYPT_KEY=$VITE_DES_ENCRYPT_KEY
ENV VITE_ARTICLE_API_URL=$VITE_ARTICLE_API_URL
ENV VITE_TINYMCE_LICENSE_KEY=$VITE_TINYMCE_LICENSE_KEY
ENV VITE_RESOURCE_URL=$VITE_RESOURCE_URL
ENV VITE_RESOURCE_PROJECT_URL=$VITE_RESOURCE_PROJECT_URL
ENV VITE_API_DVC_URL=$VITE_API_DVC_URL
ENV VITE_APP_VERSION=$VITE_APP_VERSION

COPY package*.json .
COPY yarn*.lock .
RUN yarn install --frozen-lockfile
COPY . .
RUN yarn build

#Stage 2
FROM nginx:1.25-alpine AS run-stage
COPY ./nginx.conf /etc/nginx/nginx.conf
COPY --from=build-stage /app/dist /usr/share/nginx/html
CMD ["nginx", "-g", "daemon off;"]
