generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKING
  SHIPPED
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum CheckoutType {
  USER
  GUEST
}

enum ShippingMethod {
  STANDARD
  EXPRESS
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  MOMO
  ZALOPAY
}

enum StockMovementType {
  IMPORT
  EXPORT
  ADJUST
}

enum NotificationType {
  SYSTEM
  LOW_STOCK
  ORDER
  MAIL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  OTHER
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id             String      @id @default(cuid())
  fullName       String
  email          String      @unique
  passwordHash   String?
  phone          String?
  avatarUrl      String?
  googleId       String?     @unique
  status         UserStatus  @default(ACTIVE)
  roleId         String?
  role           Role?       @relation(fields: [roleId], references: [id])
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]
  stockMovements StockMovement[]
  notifications  Notification[]
  auditLogs      AuditLog[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([roleId])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  email       String?
  address     String?
  taxCode     String?
  note        String?
  products    Product[]
  purchaseOrders PurchaseOrder[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Customer {
  id            String       @id @default(cuid())
  fullName      String
  phone         String?      @unique
  email         String?      @unique
  address       String?
  note          String?
  salesOrders   SalesOrder[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Product {
  id              String              @id @default(cuid())
  sku             String              @unique
  name            String
  slug            String              @unique
  categoryId      String?
  supplierId      String?
  unit            String
  importPrice     Decimal             @db.Decimal(12, 2)
  salePrice       Decimal             @db.Decimal(12, 2)
  stockQuantity   Int                 @default(0)
  minStockLevel   Int                 @default(5)
  description     String?
  status          String              @default("ACTIVE")
  category        Category?           @relation(fields: [categoryId], references: [id])
  supplier        Supplier?           @relation(fields: [supplierId], references: [id])
  images          ProductImage[]
  stockMovements  StockMovement[]
  purchaseItems   PurchaseOrderItem[]
  salesItems      SalesOrderItem[]
  aiSuggestions   AIStockRecommendation[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([categoryId])
  @@index([supplierId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  imageUrl  String
  isMain    Boolean  @default(false)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([productId])
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  orderCode      String              @unique
  supplierId     String?
  createdById    String?
  totalAmount    Decimal             @db.Decimal(12, 2)
  note           String?
  status         OrderStatus         @default(PENDING)
  supplier       Supplier?           @relation(fields: [supplierId], references: [id])
  createdBy      User?               @relation(fields: [createdById], references: [id])
  items          PurchaseOrderItem[]
  stockMovements StockMovement[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([supplierId])
  @@index([createdById])
}

model PurchaseOrderItem {
  id              String         @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  importPrice     Decimal        @db.Decimal(12, 2)
  subtotal        Decimal        @db.Decimal(12, 2)
  purchaseOrder   PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

model SalesOrder {
  id             String           @id @default(cuid())
  orderCode      String           @unique
  checkoutType   CheckoutType     @default(USER)
  customerId     String?
  staffId        String?
  guestName      String?
  guestPhone     String?
  guestEmail     String?
  guestAddress   String?
  totalAmount    Decimal          @db.Decimal(12, 2)
  discountAmount Decimal          @default(0) @db.Decimal(12, 2)
  shippingFee    Decimal          @default(0) @db.Decimal(12, 2)
  finalAmount    Decimal          @db.Decimal(12, 2)
  shippingMethod ShippingMethod   @default(STANDARD)
  paymentMethod  PaymentMethod    @default(COD)
  paymentStatus  PaymentStatus    @default(UNPAID)
  orderStatus    OrderStatus      @default(PENDING)
  note           String?
  customer       Customer?        @relation(fields: [customerId], references: [id])
  staff          User?            @relation(fields: [staffId], references: [id])
  items          SalesOrderItem[]
  payments       Payment[]
  invoice        Invoice?
  stockMovements StockMovement[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([customerId])
  @@index([staffId])
  @@index([checkoutType])
  @@index([guestPhone])
}

model SalesOrderItem {
  id           String      @id @default(cuid())
  salesOrderId String
  productId    String
  quantity     Int
  unitPrice    Decimal     @db.Decimal(12, 2)
  subtotal     Decimal     @db.Decimal(12, 2)
  salesOrder   SalesOrder  @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product      Product     @relation(fields: [productId], references: [id])

  @@index([salesOrderId])
  @@index([productId])
}

model Payment {
  id           String        @id @default(cuid())
  salesOrderId String
  amount       Decimal       @db.Decimal(12, 2)
  method       String
  note         String?
  paidAt       DateTime      @default(now())
  salesOrder   SalesOrder    @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  @@index([salesOrderId])
}

model Invoice {
  id           String      @id @default(cuid())
  salesOrderId String      @unique
  invoiceCode  String      @unique
  pdfUrl       String?
  issuedAt     DateTime    @default(now())
  salesOrder   SalesOrder  @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
}

model StockMovement {
  id            String            @id @default(cuid())
  productId     String
  type          StockMovementType
  quantity      Int
  purchaseOrderId String?
  salesOrderId  String?
  note          String?
  createdById   String?
  product       Product           @relation(fields: [productId], references: [id])
  createdBy     User?             @relation(fields: [createdById], references: [id])
  purchaseOrder  PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])
  salesOrder     SalesOrder?       @relation(fields: [salesOrderId], references: [id])
  createdAt     DateTime          @default(now())

  @@index([productId])
  @@index([createdById])
  @@index([purchaseOrderId])
  @@index([salesOrderId])
}

model AIStockRecommendation {
  id                    String   @id @default(cuid())
  productId             String
  currentStock          Int
  averageDailySales     Float
  recommendedQuantity   Int
  riskLevel             String
  note                  String?
  product               Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())

  @@index([productId])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String?
  type        NotificationType @default(SYSTEM)
  title       String
  content     String
  isRead      Boolean          @default(false)
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())

  @@index([userId])
}

model EmailLog {
  id          String   @id @default(cuid())
  to          String
  subject     String
  content     String?
  status      String
  error       String?
  createdAt   DateTime @default(now())
}

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  action      AuditAction
  entityName  String?
  entityId    String?
  beforeData  Json?
  afterData   Json?
  ipAddress   String?
  userAgent   String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())

  @@index([userId])
}
